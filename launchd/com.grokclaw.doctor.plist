  <string>/tmp/grokclaw-doctor.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/grokclaw-doctor.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HOME</key>
    <string>/Users/jarvis</string>
    <key>OPENCLAW_CONFIG_PATH</key>
    <string>/Users/jarvis/.openclaw/openclaw.json</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
